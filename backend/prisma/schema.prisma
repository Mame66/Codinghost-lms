generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int      @id @default(autoincrement())
  nom           String
  prenom        String
  email         String   @unique
  login         String   @unique
  password      String
  plainPassword String?
  role          Role     @default(STUDENT)
  createdAt     DateTime @default(now())

  student          Student?
  taughtGroups     Group[]  @relation("TeacherGroups")
  supervisedGroups Group[]  @relation("SupervisorGroups")
}

enum Role {
  ADMIN
  TEACHER
  TEACHER_VIEW
  STUDENT
}

model Student {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
  age         Int?
  parentNom   String?
  parentTel   String?
  parentEmail String?
  createdAt   DateTime @default(now())

  enrollments Enrollment[]
  homeworks   Homework[]
  payments    Payment[]
  contracts  Contract[]
}

model Course {
  id            Int      @id @default(autoincrement())
  titre         String
  description   String?
  niveau        String?
  lockedByAdmin Boolean  @default(false)
  createdBy     Int?
  createdAt     DateTime @default(now())
  modules      Module[]
  chapters     Chapter[]
  courseGroups CourseGroup[]
}

model CourseGroup {
  id       Int    @id @default(autoincrement())
  courseId Int
  course   Course @relation(fields: [courseId], references: [id])
  groupId  Int
  group    Group  @relation(fields: [groupId], references: [id])

  @@unique([courseId, groupId])
}

model Chapter {
  id       Int     @id @default(autoincrement())
  courseId Int
  course   Course  @relation(fields: [courseId], references: [id])
  titre    String
  ordre    Int
  locked   Boolean @default(false)
  moduleId    Int?
  module      Module?     @relation(fields: [moduleId], references: [id], onDelete: SetNull)

  tasks    Task[]
}
model Module {
  id          Int       @id @default(autoincrement())
  titre       String
  description String?
  ordre       Int       @default(0)
  locked      Boolean   @default(false)
  courseId    Int
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  chapters    Chapter[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Task {
  id             Int      @id @default(autoincrement())
  chapterId      Int
  chapter        Chapter  @relation(fields: [chapterId], references: [id])
  titre          String
  type           TaskType
  contenuUrl     String?
  description    String?
  scriptContent  String?
  scriptLanguage String?
  ordre          Int
  locked         Boolean  @default(false)
  lockedByAdmin  Boolean  @default(false)

  questions QcmQuestion[]
  homeworks Homework[]
}

enum TaskType {
  SLIDE
  QCM
  DEVOIR
  SCRIPT
}

model Group {
  id           Int         @id @default(autoincrement())
  titre        String
  teacherId    Int?
  teacher      User?       @relation("TeacherGroups", fields: [teacherId], references: [id])
  supervisorId Int?
  supervisor   User?       @relation("SupervisorGroups", fields: [supervisorId], references: [id])
  lieu         String?
  statut       GroupStatut @default(INSCRIPTION)
  format       GroupFormat @default(OFFLINE)
  type         GroupType   @default(GROUPE)
  createdAt    DateTime    @default(now())
  ville  String?

  enrollments  Enrollment[]
  courseGroups CourseGroup[]
  payments     Payment[]
  contracts  Contract[]
}

enum GroupStatut {
  ACTIF
  INSCRIPTION
  SUSPENDU
  TERMINE
}

enum GroupFormat {
  ONLINE
  OFFLINE
  HYBRIDE
}

enum GroupType {
  GROUPE
  INTRO
  INTENSIF
  INDIVIDUEL
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id])
  createdAt DateTime @default(now())

  attendance Attendance[]
}

model Attendance {
  id           Int        @id @default(autoincrement())
  enrollmentId Int
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  date         DateTime
  statut       AttStatut  @default(ABSENT)
}

enum AttStatut {
  PRESENT
  ABSENT
  EXCUSE
  NON_COMMENCE
}

model Homework {
  id          Int            @id @default(autoincrement())
  taskId      Int
  task        Task           @relation(fields: [taskId], references: [id])
  studentId   Int
  student     Student        @relation(fields: [studentId], references: [id])
  contenu     String?
  fichierUrl  String?
  lienRendu   String?
  qcmAnswers  Json?
  qcmSoumis   Boolean        @default(false)
  note        Float?
  commentaire String?
  statut      HomeworkStatut @default(EN_ATTENTE)
  createdAt   DateTime       @default(now())

  files HomeworkFile[]
}

enum HomeworkStatut {
  EN_ATTENTE
  RENDU
  CORRIGE
}

model HomeworkFile {
  id         Int      @id @default(autoincrement())
  homeworkId Int
  homework   Homework @relation(fields: [homeworkId], references: [id])
  fileName   String
  fileUrl    String
  fileType   String
  createdAt  DateTime @default(now())
}

model QcmQuestion {
  id       Int      @id @default(autoincrement())
  taskId   Int
  task     Task     @relation(fields: [taskId], references: [id])
  question String
  options  String[]
  correct  Int
  ordre    Int      @default(1)
}

model Payment {
  id          Int           @id @default(autoincrement())
  studentId   Int
  student     Student       @relation(fields: [studentId], references: [id])
  groupId     Int
  group       Group         @relation(fields: [groupId], references: [id])
  montant     Float
  devise      String        @default("EUR")
  statut      PaymentStatut @default(EN_ATTENTE)
  description String?
  createdAt   DateTime      @default(now())
}

enum PaymentStatut {
  PAYE
  EN_ATTENTE
  RETARD
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int
  titre     String
  message   String
  type      NotifType
  lu        Boolean   @default(false)
  createdAt DateTime  @default(now())
}

enum NotifType {
  NOTE
  DEVOIR
  INFO
}
enum PaymentMode {
  ONCE
  THREE_TIMES
  MONTHLY
}

enum ContractStatus {
  DRAFT
  ACTIVE
  COMPLETED
  CANCELLED
}

enum InstallmentStatus {
  PENDING
  PAID
  LATE
}

model Contract {
  id               Int            @id @default(autoincrement())
  number           String         @unique
  studentId        Int
  student          Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  groupId          Int
  group            Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)

  parentName       String?
  parentEmail      String?
  parentSignature  String?

  schoolYear       String         @default("2025-2026")
  courseName       String
  courseDay        String?
  courseStartDate  String?
  nbCours          Int            @default(32)
  ville  String?  @default("Thionville")
  totalAmount      Float
  depositAmount    Float          @default(100)
  depositPaidAt    DateTime?
  depositMethod    String?
  paymentMode      PaymentMode    @default(ONCE)

  status           ContractStatus @default(DRAFT)
  notes            String?
  signedAt         DateTime?

  installments     Installment[]
  emailLogs        EmailLog[]

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Installment {
  id          Int               @id @default(autoincrement())
  contractId  Int
  contract    Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
  number      Int
  amount      Float
  dueDate     DateTime
  paidAt      DateTime?
  paidAmount  Float?
  method      String?
  reference   String?
  status      InstallmentStatus @default(PENDING)
  createdAt   DateTime          @default(now())
}

model EmailLog {
  id         Int       @id @default(autoincrement())
  contractId Int?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  to         String
  subject    String
  type       String
  sentAt     DateTime  @default(now())
  success    Boolean   @default(true)
  error      String?
}