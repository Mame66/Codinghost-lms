generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  nom       String
  prenom    String
  email     String   @unique
  login     String   @unique
  password  String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())

  student          Student?
  taughtGroups     Group[]  @relation("TeacherGroups")
  supervisedGroups Group[]  @relation("SupervisorGroups")
}

enum Role {
  ADMIN
  TEACHER
  TEACHER_VIEW
  STUDENT
}

model Student {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id])
  age         Int?
  parentNom   String?
  parentTel   String?
  parentEmail String?
  createdAt   DateTime @default(now())

  enrollments Enrollment[]
  homeworks   Homework[]
}

model Course {
  id          Int      @id @default(autoincrement())
  titre       String
  description String?
  niveau      String?
  groupId     Int?
  group       Group?   @relation("CourseGroup", fields: [groupId], references: [id])
  createdAt   DateTime @default(now())

  chapters    Chapter[]
}

model Chapter {
  id       Int     @id @default(autoincrement())
  courseId Int
  course   Course  @relation(fields: [courseId], references: [id])
  titre    String
  ordre    Int
  locked   Boolean @default(true)

  tasks    Task[]
}

model Task {
  id         Int      @id @default(autoincrement())
  chapterId  Int
  chapter    Chapter  @relation(fields: [chapterId], references: [id])
  groupId    Int?
  group      Group?   @relation("TaskGroup", fields: [groupId], references: [id])
  titre      String
  type       TaskType
  contenuUrl String?
  ordre      Int
  locked     Boolean  @default(false)
  questions  QcmQuestion[]

  homeworks  Homework[]
}

enum TaskType {
  SLIDE
    QCM
    DEVOIR
}

model Group {
  id           Int         @id @default(autoincrement())
  titre        String
  teacherId    Int?
  teacher      User?       @relation("TeacherGroups", fields: [teacherId], references: [id])
  supervisorId Int?
  supervisor   User?       @relation("SupervisorGroups", fields: [supervisorId], references: [id])
  lieu         String?
  statut       GroupStatut @default(INSCRIPTION)
  format       GroupFormat @default(OFFLINE)
  type         GroupType   @default(GROUPE)
  createdAt    DateTime    @default(now())

  enrollments  Enrollment[]
  courses      Course[]     @relation("CourseGroup")
  tasks        Task[]       @relation("TaskGroup")
}

enum GroupStatut {
  ACTIF
  INSCRIPTION
  SUSPENDU
  TERMINE
}

enum GroupFormat {
  ONLINE
  OFFLINE
  HYBRIDE
}

enum GroupType {
  GROUPE
  INTRO
  INTENSIF
  INDIVIDUEL
}

model Enrollment {
  id        Int      @id @default(autoincrement())
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id])
  groupId   Int
  group     Group    @relation(fields: [groupId], references: [id])
  createdAt DateTime @default(now())

  attendance Attendance[]
}

model Attendance {
  id           Int        @id @default(autoincrement())
  enrollmentId Int
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id])
  date         DateTime
  statut       AttStatut  @default(ABSENT)
}

enum AttStatut {
  PRESENT
  ABSENT
  EXCUSE
}

model Homework {
  id          Int            @id @default(autoincrement())
  taskId      Int
  task        Task           @relation(fields: [taskId], references: [id])
  studentId   Int
  student     Student        @relation(fields: [studentId], references: [id])
  contenu     String?
  fichierUrl  String?
  note        Float?
  commentaire String?
  statut      HomeworkStatut @default(RENDU)
  createdAt   DateTime       @default(now())
  lienRendu   String?
  files       HomeworkFile[]
  qcmAnswers  Json?
}

enum HomeworkStatut {
  RENDU
  CORRIGE
  EN_ATTENTE
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int
  titre     String
  message   String
  type      NotifType
  lu        Boolean   @default(false)
  createdAt DateTime  @default(now())
}

enum NotifType {
  NOTE
  DEVOIR
  INFO
}
model QcmQuestion {
  id       Int          @id @default(autoincrement())
  taskId   Int
  task     Task         @relation(fields: [taskId], references: [id])
  question String
  options  String[]
  correct  Int
  ordre    Int          @default(1)
}

model HomeworkFile {
  id         Int      @id @default(autoincrement())
  homeworkId Int
  homework   Homework @relation(fields: [homeworkId], references: [id])
  fileName   String
  fileUrl    String
  fileType   String
  createdAt  DateTime @default(now())
}